[Unit]
Description=Scheduled SEO Audit Worker
After=network.target postgresql.service

[Service]
Type=simple
User=root
WorkingDirectory=/var/www/seo-pulse
ExecStart=/usr/bin/npx tsx scripts/scheduled-audit.ts
Restart=always
RestartSec=60
Environment=NODE_ENV=production

[Install]
WantedBy=multi-user.target
